{% extends 'base.html.twig' %}

{% block title %}Accueil
{% endblock %}

{% block body %}
<section id="accueil" class="hero-section text-center container">
	<div class="row align-items-center justify-content-center">
		<div class="col-lg-6">
			<h1 class="fw-bold display-4">Damien Chauveau</h1>
			<h2 class="text-success fw-semibold mb-3">Développeur Back-End PHP / Symfony</h2>
			<p class="mb-4">
				Je conçois et développe des applications web en PHP avec Symfony, en transformant des idées
				en solutions concrètes et fonctionnelles.
				J’accorde une attention particulière à la structure des projets,
				à la qualité du code et à la maintenabilité des applications.
			</p>
			<div class="d-flex justify-content-center gap-3">
				<a href="{{ path('app_portfolio') }}" class="btn btn-primary-custom px-4">Voir mes projets</a>
				<a href="{{ asset('files/cv-damien-chauveau.pdf') }}?v=2" class="btn btn-outline-light px-4"
					target="_blank" rel="noopener noreferrer">
					Télécharger mon CV
				</a>
			</div>
			<div class="social-links">
				<a href="https://github.com/DamienCH33" title="GitHub" target="_blank" rel="noopener noreferrer">
					<svg width="24" height="24" fill="currentColor" viewbox="0 0 24 24">
						<path
							d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
					</svg>
				</a>
				<a href="https://www.linkedin.com/in/damien-chauveau-747892100/" title="LinkedIn" target="_blank"
					rel="noopener noreferrer">
					<svg width="24" height="24" fill="currentColor" viewbox="0 0 24 24">
						<path
							d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
					</svg>
				</a>
			</div>
		</div>
		<div class="col-lg-4 mt-5 mt-lg-0 text-center">
			<div class="profile-photo">
				<img src="{{ asset('image/portfolio_media/damien_chauveau_photo.png') }}?v=3" alt="Photo de Damien">
			</div>
		</div>
	</div>
</section>

<!-- Skill Section -->
<section id="competences" class="py-5 section-bg">
	<div class="container">
		<h2 class="section-title text-center mb-4">Compétences</h2>
		<div class="container seo-text">
			<p>
				Mes compétences couvrent principalement le développement backend avec PHP et Symfony,
				la conception d’applications web, la gestion de bases de données relationnelles ainsi
				que l’utilisation d’outils modernes de développement.
			</p>
		</div>
		{% set categories = ['Langage', 'Framework', 'Architecture', 'Base de données', 'Outils /DevOps', 'Qualité / Tests'] %}

<div class="row g-4">

    {% for category in categories %}
        <div class="col-lg-4 col-md-6">
            <div class="skill-category h-100">

                <h3 class="text-center">{{ category }}</h3>

                {% for skill in skills %}
                    {% if skill.category == category %}
                        <div class="skill-item">
                            <img src="{{ skill.logo }}" class="skill-logo" alt="{{ skill.name }}">
                            <span>{{ skill.name }}</span>
                        </div>
                    {% endif %}
                {% endfor %}

            </div>
        </div>
    {% endfor %}

</div>
	</div>
</section>

<!-- Portfolio -->
<section id="portfolio" class="py-5">
	<div class="container">
		<h2 class="section-title">Portfolio</h2>
		<div class="container mt-4 seo-text">
			<p>
				Ce portfolio présente plusieurs projets réalisés avec PHP et le framework Symfony.
				Ces applications web illustrent mon travail autour de l’architecture backend,
				de la gestion de base de données, des API et des bonnes pratiques de développement.
			</p>
		</div>
		<div class="row g-4">
			{% for project in projects %}
			<div class="col">
				<div class="project-card h-100">
					<img src="{{ project.image }}" alt="{{ project.title }}"
						class="img-fluid rounded-top">
					<div class="p-3 d-flex flex-column h-100">
						<h4 class="project-title">
							{{ project.title }}
						</h4>
						<p class="text-muted small mb-3">
							{{ project.description }}
						</p>
						<div class="project-tech mb-3">
							{% for skill in project.techStack %}
							<span class="badge bg-success me-1">
								{{ skill.name }}
							</span>
							{% endfor %}
						</div>
						<div class="project-actions mt-auto">
							<a href="{{ project.link }}" target="_blank" class="btn btn-sm btn-outline-light  bi bi-github">
								Voir le code
							</a>
						</div>
					</div>
				</div>
			</div>
			{% endfor %}
		</div>
		<div class="d-flex justify-content-center mt-4">
			<a href="{{ path('app_portfolio') }}" class="btn btn-primary px-4 py-2">Voir plus de projets</a>
		</div>
	</div>
</section>

<!-- Education Section -->
<section class="education">
	<div class="container">
		<h2>Diplômes & Formation</h2>
		<div class="container seo-text">
			<p>
				J’ai obtenu la certification professionnelle Développeur Concepteur Logiciel
				(niveau 6 – bac+3/4) délivrée par OpenClassrooms. Cette formation m’a permis
				de développer des applications web complètes en PHP avec Symfony, en appliquant
				les bonnes pratiques de développement et d’architecture logicielle.
			</p>
		</div>
		<div class="education-list">
			{% for education in educations %}
			<div class="education-item">
				<div class="education-year">
					{{ education.yearStart }}
					-
					{% if education.yearEnd is not null %}
					{{ education.yearEnd }}
					{% else %}
					En cours
					{% endif %}
				</div>
				{{ education.title}}</h3>
				<p>{{ education.institution}}</p>
			</div>
			{% endfor %}
		</div>
	</div>
</section>

<!-- Contact Section -->
<section id="contact" class="py-5 section-bg">
    <div class="container">

        <h2 class="section-title text-center mb-3">Contact</h2>

        <p class="text-center text-muted mb-5 contact-intro">
            Une question, une proposition de collaboration ou une opportunité
            professionnelle ? N’hésitez pas à me laisser un message.
        </p>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success text-center">{{ message }}</div>
        {% endfor %}

        {% for message in app.flashes('danger') %}
            <div class="alert alert-danger text-center">{{ message }}</div>
        {% endfor %}

        <div class="contact-card mx-auto">

            {% include "form_contact.html.twig" %}

        </div>

        <div class="contact-alt text-center mt-5">
            <p class="text-muted mb-2">
                Vous pouvez également me contacter directement via :
            </p>

            <span class="mx-2">•</span>

            <a href="https://github.com/DamienCH33" target="_blank" class="contact-link">
                GitHub
            </a>

            <span class="mx-2">•</span>

            <a href="https://linkedin.com/in/tonprofil" target="_blank" class="contact-link">
                LinkedIn
            </a>
        </div>

    </div>
</section>
{% endblock %}