<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="utf-8">
		<title>
			{% block title %}Tableau de bord - Admin
			{% endblock %}
		</title>
		<meta name="viewport" content="width=device-width, initial-scale=1">

		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
		<link href="/styles/style.css" rel="stylesheet"> {% block stylesheets %}{% endblock %}
		</head>
		<body>
			<div class="container-fluid">
				<div
					class="row">
					<!-- Sidebar -->
					<nav class="col-12 col-md-3 col-lg-2 sidebar p-3 min-vh-100 sidebar-blue">
						<a class="nav-link" href="{{ path('app_home') }}"><h4 class="mb-4">Admin</h4></a>
						<a href="{{ path('admin_dashboard') }}" class="d-block mb-2">🏠 Tableau de bord</a>
						<a href="{{ path('admin_skills') }}" class="d-block mb-2">🧩 Compétences</a>
						<a href="{{ path('admin_projects') }}" class="d-block mb-2">📁 Projets</a>
						<a href="{{ path('admin_education') }}" class="d-block mb-2">🎓 Diplômes</a>
						<hr class="border-light">
						<div class="mt-3 small-muted">Connecté en tant que</div>
						<strong class="small-muted">{{ app.user.email|default('Administrateur') }}</strong>

						<div class="mt-3">
							<a href="{{ path('app_logout') }}" class="btn btn-danger btn-sm w-100">
								🚪 Déconnexion
							</a>
						</div>
					</nav>

					<main class="col-12 col-md-9 col-lg-10 py-4"> {% block body %}{% endblock %}
						</main>
					</div>
				</div>

				<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
				{% block javascripts %}{% endblock %}
			</body>
		</html>
