<!DOCTYPE html>
<html lang="fr">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta property="og:title" content="Damien Chauveau | Développeur PHP Symfony">

	<meta property="og:description"
		content="Portfolio de Damien Chauveau, développeur backend PHP Symfony. Découvrez mes projets et compétences en développement web.">

	<meta property="og:url" content="{{ app.request.schemeAndHttpHost }}">

	<meta property="og:type" content="website">

	<meta property="og:locale" content="fr_FR">

	<meta name="description"
		content="Portfolio de Damien Chauveau, développeur backend PHP Symfony. Découvrez mes projets, compétences et réalisations.">
	<meta name="author" content="Damien Chauveau">
	<title>
		{% block title %}Portfolio - Damien
		{% endblock %}
	</title>

	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
	<link href="/styles/style.css" rel="stylesheet">
</head>

<body>
	<nav class="navbar navbar-expand-lg navbar-dark navbar-custom fixed-top" aria-label="Main navigation">
		<div class="container">
<a class="navbar-brand brand-logo" href="{{ path('app_home') }}">
	<span class="brand-badge">

		<span class="brand-bracket">&lt;</span>

		<span class="brand-first">Damien</span>
		<span class="brand-last">CHAUVEAU</span>

		<span class="brand-bracket">/&gt;</span>

	</span>
</a>
			<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
				<span class="navbar-toggler-icon"></span>
			</button>
			<div class="collapse navbar-collapse justify-content-end" id="navbarNav">
				<ul class="navbar-nav">
					<li class="nav-item">
						<a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('app_portfolio') }}">Portfolio</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('app_about') }}">À propos</a>
					</li>
					<li class="nav-item">
						<a class="nav-link" href="{{ path('app_contact') }}">Contact</a>
					</li>
				</ul>
			</div>
		</div>
	</nav>

	<main class="pt-5">
		{% block body %}{% endblock %}
	</main>

	{% set yearRef = 2025 %}
	<footer class="footer py-4 mt-5 border-top">
		<div class="container text-center">
			<p class="footer-name mb-3">
				©
				{% if yearRef < "now" |date("Y") %} {{ yearRef }} - {{ "now" |date("Y") }} {% else %} {{ yearRef }} {%
					endif %} — Damien Chauveau — Tous droits réservés </p>
					<div class="footer-links">
						<a href="https://github.com/DamienCH33" target="_blank" rel="me noopener" title="GitHub">
							<i class="bi bi-github"></i>
						</a>
						<a href="https://linkedin.com/in/damien-chauveau-747892100/" target="_blank" rel="me noopener"
							title="LinkedIn">
							<i class="bi bi-linkedin"></i>
						</a>
					</div>
		</div>
	</footer>

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>